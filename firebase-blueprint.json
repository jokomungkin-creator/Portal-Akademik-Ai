{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role in the application" }
      },
      "required": ["uid", "email", "displayName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile document"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": {
        "title": "Chat Message",
        "description": "A single chat message in the conversation history",
        "type": "object",
        "properties": {
          "role": { "type": "string", "enum": ["user", "model"], "description": "The sender of the message" },
          "text": { "type": "string", "description": "The content of the message" },
          "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent" }
        },
        "required": ["role", "text", "timestamp"]
      },
      "description": "Chat history subcollection"
    },
    "/users/{userId}/generations/{genId}": {
      "schema": {
        "title": "AI Generation",
        "description": "A single AI generated result",
        "type": "object",
        "properties": {
          "tool": { "type": "string", "description": "The name of the tool used" },
          "content": { "type": "string", "description": "The generated content" },
          "timestamp": { "type": "string", "format": "date-time", "description": "When the content was generated" }
        },
        "required": ["tool", "content", "timestamp"]
      },
      "description": "AI generation history subcollection"
    }
  }
}
